# ============================================================
# Panel Ferriperfiles — ejemplo de configuración
# Copia este archivo como .env y reemplaza los valores.
# Nunca compartas ni subas el archivo .env real a Git.
# ============================================================

# Frontend / Supabase (la anon key está diseñada para el cliente;
# la seguridad real depende de las políticas RLS de Supabase)
VITE_SUPABASE_URL=https://TU_PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=TU_SUPABASE_ANON_KEY
VITE_API_URL=http://localhost:8000

# Solo para scripts de administración ejecutados desde servidor o terminal.
# Nunca debe usarse en el navegador ni subirse a Git.
SUPABASE_SERVICE_ROLE_KEY=TU_SERVICE_ROLE_KEY

# Siigo API — solo servidor, MCP o n8n
SIIGO_USERNAME=TU_USUARIO_API_SIIGO
SIIGO_ACCESS_KEY=TU_ACCESS_KEY_SIIGO
SIIGO_PARTNER_ID=ferripanel
SIIGO_BASE_URL=https://api.siigo.com

# MCP Siigo — comenzaremos únicamente en modo lectura
SIIGO_MCP_MODE=read_only

# Bloque 0 — interruptor temporal para cualquier ruta heredada que escriba en Siigo.
# Debe permanecer en false hasta que Integration Service + MCP controlen las escrituras.
UNSAFE_DIRECT_SIIGO_WRITES_ENABLED=false

# MCP de Siigo para esta celda (Streamable HTTP; sin URL compartida por defecto)
ORBIT_MCP_URL=https://tu-gateway-mcp.example.com/mcp
ORBIT_MCP_API_KEY=tu_orbit_api_key

# Worker protegido: n8n llama al worker y solo este proceso invoca siigo_create_quotation.
# Los IDs se obtienen de la cuenta Siigo de Ferriperfiles; nunca usar valores de ejemplo en producción.
INTEGRATION_WORKER_TOKEN=un_secreto_largo_y_unico_por_celda
SIIGO_QUOTATION_DOCUMENT_ID=12345
SIIGO_DEFAULT_SELLER_ID=629
SIIGO_CUSTOMER_BRANCH_OFFICE=0
SIIGO_DEFAULT_TAX_ID=

# OCR / Inteligencia artificial — solo servidor
GOOGLE_CLOUD_API_KEY=TU_GOOGLE_CLOUD_API_KEY
OPENAI_API_KEY=TU_OPENAI_API_KEY

# Servidor de correo — solo servidor
MAILER_SENDER_EMAIL=correo@ferriperfiles.com
SMTP_ADDRESS=smtp.gmail.com
SMTP_PORT=587
SMTP_PASSWORD=TU_PASSWORD_DE_APLICACION

# Backend Node
PORT=3001
